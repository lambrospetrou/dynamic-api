{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "Bundler",
		"strict": true,
		"skipLibCheck": true,
		"lib": ["ES2022"],
		"types": [
			"./worker-configuration.d.ts",
			"node",
			"@cloudflare/vitest-pool-workers/types" // provides `cloudflare:test` and `cloudflare:workers` types
		]
	},
	"include": [
		"./**/*.ts",
		"./worker-configuration.d.ts" // output of `wrangler types`
	]
}
